def create_appointment():
    show_patients()
    patient_id = int(input("Введите ID пациента: "))

    show_doctors()
    doctor_id = int(input("Введите ID врача: "))

    conn = connect()
    cursor = conn.cursor()

    cursor.execute("""
        SELECT id, date, time
        FROM schedules
        WHERE doctor_id = ? AND is_available = 1
    """, (doctor_id,))

    schedules = cursor.fetchall()

    if not schedules:
        print("У выбранного врача нет свободного времени.")
        conn.close()
        return

    print("\nДоступное время:")
    for schedule in schedules:
        print(f"{schedule[0]}. Дата: {schedule[1]} | Время: {schedule[2]}")

    schedule_id = int(input("Введите ID времени приёма: "))

    cursor.execute("""
        SELECT id
        FROM schedules
        WHERE id = ? AND doctor_id = ? AND is_available = 1
    """, (schedule_id, doctor_id))

    result = cursor.fetchone()

    if result is None:
        print("Ошибка: выбранное время недоступно.")
        conn.close()
        return

    cursor.execute("""
        INSERT INTO appointments (patient_id, doctor_id, schedule_id, status)
        VALUES (?, ?, ?, 'active')
    """, (patient_id, doctor_id, schedule_id))

    cursor.execute("""
        UPDATE schedules
        SET is_available = 0
        WHERE id = ?
    """, (schedule_id,))

    conn.commit()
    conn.close()

    print("Запись на приём успешно создана.")


def show_appointments():
    conn = connect()
    cursor = conn.cursor()

    cursor.execute("""
        SELECT 
            appointments.id,
            patients.full_name,
            doctors.full_name,
            doctors.specialization,
            schedules.date,
            schedules.time,
            appointments.status
        FROM appointments
        JOIN patients ON appointments.patient_id = patients.id
        JOIN doctors ON appointments.doctor_id = doctors.id
        JOIN schedules ON appointments.schedule_id = schedules.id
    """)

    appointments = cursor.fetchall()
    conn.close()

    if not appointments:
        print("Записей на приём пока нет.")
        return

    print("\nЗаписи на приём:")
    for app in appointments:
        print(
            f"{app[0]}. Пациент: {app[1]} | "
            f"Врач: {app[2]} | "
            f"Специальность: {app[3]} | "
            f"Дата: {app[4]} | "
            f"Время: {app[5]} | "
            f"Статус: {app[6]}"
        )


def cancel_appointment():
    show_appointments()

    appointment_id = int(input("Введите ID записи для отмены: "))

    conn = connect()
    cursor = conn.cursor()

    cursor.execute(
        "SELECT schedule_id FROM appointments WHERE id = ? AND status = 'active'",
        (appointment_id,)
    )

    result = cursor.fetchone()

    if result is None:
        print("Активная запись не найдена.")
        conn.close()
        return

    schedule_id = result[0]

    cursor.execute("""
        UPDATE appointments
        SET status = 'cancelled'
        WHERE id = ?
    """, (appointment_id,))

    cursor.execute("""
        UPDATE schedules
        SET is_available = 1
        WHERE id = ?
    """, (schedule_id,))

    conn.commit()
    conn.close()

    print("Запись отменена. Время снова доступно.")


def menu():
    while True:
        print("\n=== Система записи к врачу ===")
        print("1. Добавить пациента")
        print("2. Добавить врача")
        print("3. Показать врачей")
        print("4. Добавить расписание врачу")
        print("5. Показать свободное расписание")
        print("6. Записать пациента на приём")
        print("7. Показать все записи")
        print("8. Отменить запись")
        print("0. Выход")

        choice = input("Выберите действие: ")

        if choice == "1":
            add_patient()
        elif choice == "2":
            add_doctor()
        elif choice == "3":
            show_doctors()
        elif choice == "4":
            add_schedule()
        elif choice == "5":
            show_schedule()
        elif choice == "6":
            create_appointment()
        elif choice == "7":
            show_appointments()
        elif choice == "8":
            cancel_appointment()
        elif choice == "0":
            print("Выход из программы.")
            break
        else:
            print("Неверный пункт меню.")


create_tables()
menu()
